---
import { Image } from 'astro:assets';

import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import Landscape from "../assets/landscape-cropped-1.jpg"
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<Image src={Landscape} alt="Mount of the Holy Cross Summit" />
			<h1>Hey there!</h1>
			<p>
				I'm Jordan.
				By day, platform engineer at Ibotta building high-volume targeting APIs.
				By night, whatever my ADD points at — lately CAD, 3D printing, and embedded work, trying to understand how everything works from the silicon up.
				Based in Denver.
			</p>
		</main>
		<Footer />
	</body>
</html>
